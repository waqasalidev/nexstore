# ==========================================
# NEXSTORE ENVIRONMENT CONFIGURATION EXAMPLE
# ==========================================

# ----------------------------
# 1. EXPRESS BACKEND CONFIG
# ----------------------------
PORT=5000
NODE_ENV=production

# MongoDB Connection String (Mongoose Atlas)
MONGO_URI=mongodb+srv://<db_user>:<db_password>@cluster0.mongodb.net/nexstore?retryWrites=true&w=majority

# JWT Token Secret Key for Custom Auth
JWT_SECRET=your_production_jwt_secret_key_change_me

# Production Frontend URL (Used for CORS origin validation)
FRONTEND_URL=https://your-frontend-domain.vercel.app

# ----------------------------
# 2. GOOGLE GEMINI API KEY
# ----------------------------
GEMINI_API_KEY=AIzaSyYourGeminiApiKeyHere_RequiredForHelpdeskAndDescriptionGeneration

# ----------------------------
# 3. NODEMAILER SMTP CONFIG (Email notifications)
# ----------------------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail_sender_username@gmail.com
EMAIL_PASS=your_gmail_app_specific_password_here
ADMIN_EMAIL=your_admin_notification_recipient@gmail.com

# ----------------------------
# 4. FRONTEND REACT CLIENT CONFIG (Vite prefix required)
# ----------------------------
VITE_API_URL=https://your-backend-domain.onrender.com
VITE_SUPABASE_URL=https://twtnlmmugkoetuqtezcv.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=mock-key-123
